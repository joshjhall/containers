{
  "markdown": {
    "textWrap": "maintain"
  },
  "yaml": {
    "printWidth": 120
  },
  "json": {
    "indentWidth": 2,
    "lineWidth": 100
  },
  "excludes": [
    "CHANGELOG.md",
    "tests/results/**",
    "target/**",
    "node_modules/**",
    ".git/**",
    ".vscode/**",
    ".devcontainer/**",
    "**/*.lock",
    "crates/containers-common/testdata/golden/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.20.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ]
}
