{{- /* devcontainer.json.tmpl — generated by igor */ -}}
// === IGOR:BEGIN ===
// Generated by igor — do not edit between markers
// Regenerate with: igor update
{
  "name": "{{ .Project.Name }}",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace/{{ .Project.Name }}",
  "overrideCommand": false,
  "postCreateCommand": "echo 'Container created'",
  "postStartCommand": "echo 'Container started'",
  "customizations": {
    "vscode": {
      "extensions": [
{{- range $i, $ext := .VSCodeExtensions }}
        "{{ $ext }}"{{ if lt (add $i 1) (len $.VSCodeExtensions) }},{{ end }}
{{- end }}
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash",
            "args": ["-l"]
          }
        }
      }
    }
  },
  "remoteUser": "{{ .Project.Username }}"
}
// === IGOR:END ===
