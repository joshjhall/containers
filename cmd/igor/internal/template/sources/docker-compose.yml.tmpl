{{- /* docker-compose.yml.tmpl — generated by igor */ -}}
# === IGOR:BEGIN ===
# Generated by igor — do not edit between markers
# Regenerate with: igor update

services:
  devcontainer:
    build:
      context: ../
      dockerfile: ./{{ .ContainersDir }}/Dockerfile
      args:
        - BUILDKIT_INLINE_CACHE=1
        - PROJECT_NAME={{ .Project.Name }}
        - USERNAME={{ .Project.Username }}
        - BASE_IMAGE={{ .Project.BaseImage }}
{{- $groups := groupedBuildArgs . }}
{{- range $groups }}
        # {{ .Label }}
{{- range .Args }}
{{- if .Comment }}
        - {{ .Line }}  # {{ .Comment }}
{{- else }}
        - {{ .Line }}
{{- end }}
{{- end }}
{{- end }}
    env_file:
      - path: .env
        required: false
    environment:
      - ENVIRONMENT=development
{{- if .NeedsDocker }}
      - DOCKER_BUILDKIT=1
{{- end }}
    volumes:
      # Source code
      - ../:/workspace/{{ .Project.Name }}:cached
{{- if .NeedsDocker }}
      # Docker socket
      - /var/run/docker.sock:/var/run/docker.sock
{{- end }}
{{- range .CacheVolumes }}
{{- $parts := split . ":" }}
      - {{ index $parts 0 }}:{{ index $parts 1 }}
{{- end }}
      # VS Code extensions
      - vscode-extensions:/home/{{ .Project.Username }}/.vscode-server/extensions
{{- if .NeedsBindfs }}
    cap_add:
      - SYS_ADMIN
    devices:
      - /dev/fuse
{{- end }}
    networks:
      - dev-network
    restart: unless-stopped
    stdin_open: true
    tty: true
    init: true
    command: ["sleep", "infinity"]

volumes:
{{- range .CacheVolumes }}
{{- $parts := split . ":" }}
  {{ index $parts 0 }}:
    driver: local
{{- end }}
  vscode-extensions:
    driver: local

networks:
  dev-network:
    name: {{ .Project.Name }}-dev-network
    driver: bridge
# === IGOR:END ===
