{{- /* env.tmpl — generated by igor */ -}}
# === IGOR:BEGIN ===
# Generated by igor
# Regenerate with: igor update

# Base environment
TZ=UTC
TERM=xterm-256color

# Runtime
ENVIRONMENT=development
{{- if hasFeature . "python" }}

# Python
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
PIP_NO_CACHE_DIR=1
POETRY_VIRTUALENVS_IN_PROJECT=true
POETRY_NO_INTERACTION=1
{{- end }}
{{- if hasFeature . "node" }}

# Node.js
NODE_ENV=development
NPM_CONFIG_LOGLEVEL=warn
{{- end }}
{{- if hasFeature . "rust" }}

# Rust
RUST_BACKTRACE=1
CARGO_INCREMENTAL=1
{{- end }}
{{- if hasFeature . "golang" }}

# Go
GO111MODULE=on
GOPROXY=https://proxy.golang.org,direct
{{- end }}
{{- if hasFeature . "ruby" }}

# Ruby
BUNDLE_PATH=vendor/bundle
{{- end }}
{{- if hasFeature . "docker" }}

# Docker
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
{{- end }}
{{- if hasFeature . "kubernetes" }}

# Kubernetes
KUBECONFIG=$HOME/.kube/config
{{- end }}
{{- if hasFeature . "terraform" }}

# Terraform
TF_IN_AUTOMATION=true
TF_INPUT=false
{{- end }}
{{- if hasFeature . "aws" }}

# AWS
AWS_DEFAULT_REGION=us-east-1
AWS_DEFAULT_OUTPUT=json
{{- end }}
{{- if hasFeature . "dev_tools" }}

# Dev Tools
FZF_DEFAULT_OPTS=--height 40% --layout=reverse --border --info=inline
{{- end }}
{{- if hasFeature . "ollama" }}

# Ollama
OLLAMA_HOST=http://localhost:11434
{{- end }}
# === IGOR:END ===
