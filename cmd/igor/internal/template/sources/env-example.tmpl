{{- /* env-example.tmpl — generated by igor */ -}}
# === IGOR:BEGIN ===
# Environment Configuration
# Copy to .devcontainer/.env and fill in values
# Generated by igor — regenerate with: igor update

# Base environment
TZ=UTC
TERM=xterm-256color
ENVIRONMENT=development
{{- if hasFeature . "python" }}

# Python
# PYTHONUNBUFFERED=1
# PYTHONDONTWRITEBYTECODE=1
# PIP_NO_CACHE_DIR=1
# POETRY_VIRTUALENVS_IN_PROJECT=true
{{- end }}
{{- if hasFeature . "node" }}

# Node.js
# NODE_ENV=development
# NPM_CONFIG_LOGLEVEL=warn
{{- end }}
{{- if hasFeature . "rust" }}

# Rust
# RUST_BACKTRACE=1
# CARGO_INCREMENTAL=1
{{- end }}
{{- if hasFeature . "golang" }}

# Go
# GO111MODULE=on
# GOPROXY=https://proxy.golang.org,direct
{{- end }}
{{- if hasFeature . "docker" }}

# Docker
# DOCKER_BUILDKIT=1
# COMPOSE_DOCKER_CLI_BUILD=1
{{- end }}
{{- if hasFeature . "kubernetes" }}

# Kubernetes
# KUBECONFIG=$HOME/.kube/config
{{- end }}
{{- if hasFeature . "terraform" }}

# Terraform
# TF_IN_AUTOMATION=true
# TF_INPUT=false
{{- end }}
{{- if hasFeature . "aws" }}

# AWS
# AWS_DEFAULT_REGION=us-east-1
# AWS_DEFAULT_OUTPUT=json
{{- end }}
{{- if hasFeature . "op" }}

# 1Password
# OP_SERVICE_ACCOUNT_TOKEN=
# OP_GITHUB_TOKEN_REF=op://Vault/GitHub/token
{{- end }}
{{- if hasFeature . "dev_tools" }}

# Claude Code
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_MODEL=claude-sonnet-4-6
{{- end }}
{{- if hasFeature . "ollama" }}

# Ollama
# OLLAMA_HOST=http://localhost:11434
{{- end }}
# === IGOR:END ===
