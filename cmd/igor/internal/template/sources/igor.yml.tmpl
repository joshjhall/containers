{{- /* igor.yml.tmpl — generated by igor */ -}}
# Igor configuration — tracks feature selections and generated files
# Regenerate with: igor update

schema_version: 1
containers_dir: {{ .ContainersDir }}
project:
  name: {{ .Project.Name }}
  username: {{ .Project.Username }}
  base_image: {{ .Project.BaseImage }}
features:
{{- range .EnabledFeatures }}
{{- if index $.Selection.Explicit .ID }}
  - {{ .ID }}
{{- end }}
{{- end }}
{{- if .Versions }}
versions:
{{- range $key, $val := .Versions }}
  {{ $key }}: "{{ $val }}"
{{- end }}
{{- end }}
