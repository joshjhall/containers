# === IGOR:BEGIN ===
# Generated by igor — do not edit between markers
# Regenerate with: igor update

services:
  devcontainer:
    build:
      context: ../
      dockerfile: ./containers/Dockerfile
      args:
        - BUILDKIT_INLINE_CACHE=1
        - PROJECT_NAME=fullstack
        - USERNAME=dev
        - BASE_IMAGE=debian:bookworm-slim
        - INCLUDE_PYTHON=true
        - PYTHON_VERSION=3.14.0
        - INCLUDE_PYTHON_DEV=true
        - INCLUDE_NODE=true
        - NODE_VERSION=22.12.0
        - INCLUDE_NODE_DEV=true
        - INCLUDE_RUST=true
        - RUST_VERSION=1.83.0
        - INCLUDE_RUST_DEV=true
        - INCLUDE_GOLANG=true
        - GO_VERSION=1.23.4
        - INCLUDE_GOLANG_DEV=true
        - INCLUDE_DEV_TOOLS=true
        - INCLUDE_DOCKER=true
        - INCLUDE_OP=true
        - INCLUDE_CRON=true
        - INCLUDE_BINDFS=true
        - INCLUDE_OLLAMA=true
        - INCLUDE_KUBERNETES=true
        - INCLUDE_TERRAFORM=true
        - INCLUDE_AWS=true
        - INCLUDE_POSTGRES_CLIENT=true
        - INCLUDE_REDIS_CLIENT=true
    env_file:
      - path: .env
        required: false
    environment:
      - ENVIRONMENT=development
      - DOCKER_BUILDKIT=1
    volumes:
      # Source code
      - ../:/workspace/fullstack:cached
      # Docker socket
      - /var/run/docker.sock:/var/run/docker.sock
      - pip-cache:/cache/pip
      - poetry-cache:/cache/poetry
      - npm-cache:/cache/npm
      - cargo-cache:/cache/cargo
      - rustup-cache:/cache/rustup
      - go-cache:/cache/go
      - ollama-cache:/cache/ollama
      # VS Code extensions
      - vscode-extensions:/home/dev/.vscode-server/extensions
    cap_add:
      - SYS_ADMIN
    devices:
      - /dev/fuse
    networks:
      - dev-network
    restart: unless-stopped
    stdin_open: true
    tty: true
    init: true
    command: ["sleep", "infinity"]

volumes:
  pip-cache:
    driver: local
  poetry-cache:
    driver: local
  npm-cache:
    driver: local
  cargo-cache:
    driver: local
  rustup-cache:
    driver: local
  go-cache:
    driver: local
  ollama-cache:
    driver: local
  vscode-extensions:
    driver: local

networks:
  dev-network:
    name: fullstack-dev-network
    driver: bridge
# === IGOR:END ===
