# === IGOR:BEGIN ===
# Generated by igor — do not edit between markers
# Regenerate with: igor update

services:
  devcontainer:
    build:
      context: ../
      dockerfile: ./containers/Dockerfile
      args:
        - BUILDKIT_INLINE_CACHE=1
        - PROJECT_NAME=myapp
        - USERNAME=developer
        - BASE_IMAGE=debian:trixie-slim
        - INCLUDE_PYTHON=true
        - PYTHON_VERSION=3.14.0
        - INCLUDE_PYTHON_DEV=true
    env_file:
      - path: .env
        required: false
    environment:
      - ENVIRONMENT=development
    volumes:
      # Source code
      - ../:/workspace/myapp:cached
      - pip-cache:/cache/pip
      - poetry-cache:/cache/poetry
      # VS Code extensions
      - vscode-extensions:/home/developer/.vscode-server/extensions
    networks:
      - dev-network
    restart: unless-stopped
    stdin_open: true
    tty: true
    init: true
    command: ["sleep", "infinity"]

volumes:
  pip-cache:
    driver: local
  poetry-cache:
    driver: local
  vscode-extensions:
    driver: local

networks:
  dev-network:
    name: myapp-dev-network
    driver: bridge
# === IGOR:END ===
