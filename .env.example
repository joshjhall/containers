# Container Build System Environment Variables
# Copy this file to .env and update with your values

# =============================================================================
# Container Environment
# =============================================================================
# TZ=America/Chicago
# ENVIRONMENT=development   # development | staging | production

# =============================================================================
# 1Password Integration Configuration
# =============================================================================
# IMPORTANT: OP_SERVICE_ACCOUNT_TOKEN must go in .env.secrets (not here).
# Docker Compose exposes env_file values via `docker compose config`, so
# secrets placed here will leak into VS Code Dev Containers logs.
# See .env.secrets.example for details.

# =============================================================================
# 1Password Secret Refs (OP_*_REF convention)
# =============================================================================
# Any OP_<NAME>_REF is resolved from 1Password and exported as <NAME>.
# Direct env vars always win (if <NAME> is already set, the ref is skipped).
# See CLAUDE.md for full documentation.
#
# API tokens - field name depends on your 1Password item type:
#   API_CREDENTIAL items use "credential", LOGIN items use "password", etc.
#
# OP_GITHUB_TOKEN_REF=op://Vault/GitHub-PAT/credential
# OP_GITLAB_TOKEN_REF=op://Vault/GitLab-PAT/credential
# OP_GITLAB_HOST_REF=op://Vault/GitLab-PAT/hostname
# OP_KAGI_API_KEY_REF=op://Vault/Kagi-API-Key/credential
# OP_BRAVE_API_KEY_REF=op://Vault/Brave-Search/credential

# =============================================================================
# Git Identity & SSH Keys
# =============================================================================
# Direct env vars (for non-OP users):
#
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
# GIT_AUTH_SSH_KEY=<raw private key text>
# GIT_SIGNING_SSH_KEY=<raw private key text>
#
# OP refs (resolved automatically by _op_load_secrets):
# For Identity items, the system tries "full name" first, then combines
# "first name" + "last name". Falls back to "Devcontainer" if unresolved.
#
# OP_GIT_USER_NAME_REF=op://Vault/Identity/full name
# OP_GIT_USER_EMAIL_REF=op://Vault/Identity/email
# OP_GIT_AUTH_SSH_KEY_REF=op://Vault/Git-Auth-Key/private key
# OP_GIT_SIGNING_SSH_KEY_REF=op://Vault/Git-Signing-Key/private key

# =============================================================================
# Direct GitHub/GitLab Tokens (for non-OP users)
# =============================================================================
# GITHUB_TOKEN=ghp_your_token_here
# GITLAB_TOKEN=glpat-your_token_here

# =============================================================================
# Claude Code Extra MCPs (individual developer additions)
# =============================================================================
# Additive MCP servers for your personal .env (extends team defaults)
# Three formats supported:
#   short-name       - Registered name from the MCP registry (e.g., "memory", "fetch")
#   @scope/package   - npm package, resolved via npx -y at runtime
#   name=https://... - HTTP MCP server at the given URL
#
# CLAUDE_EXTRA_MCPS=memory,@myorg/mcp-internal,my-api=http://localhost:8080/mcp

# Auto-detect GitHub/GitLab MCP from git remotes (default: true)
# CLAUDE_AUTO_DETECT_MCPS=true

# =============================================================================
# CLAUDE CODE AUTHENTICATION
# =============================================================================
# Claude Code CLI typically requires interactive authentication.
# Environment variables do NOT work with the Claude Code CLI unless you're using
# an OpenAI API compatible proxy such as LiteLLM
#
# OP_ANTHROPIC_AUTH_TOKEN_REF=op://Vault/Claude Code/credential
# OP_ANTHROPIC_BASE_URL_REF=op://Vault/Claude Code/base url
# ANTHROPIC_MODEL=claude-opus-4-6
