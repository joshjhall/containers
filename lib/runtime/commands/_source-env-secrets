#!/bin/bash
# Sourceable helper: loads .env.secrets into the current shell environment.
#
# Used by setup-git, setup-gh, setup-glab so that secrets are available
# when called from non-interactive shells (e.g., postStartCommand).
#
# Search order (first match wins):
#   1. $ENV_SECRETS_FILE  — explicit path override
#   2. $HOME/.env.secrets — user-level secrets
#   3. $PWD/.env.secrets  — project-level secrets (container WORKDIR)
#   4. /workspace/*/.env.secrets — workspace mount fallback

# Idempotency — don't re-source if already loaded in this shell
[ -n "${_ENV_SECRETS_LOADED:-}" ] && return 0

# Suppress xtrace to avoid leaking secrets
_ess_old_xtrace=$(set +o | command grep xtrace)
{ set +x; } 2>/dev/null

_ess_file=""
if [ -n "${ENV_SECRETS_FILE:-}" ] && [ -f "${ENV_SECRETS_FILE}" ]; then
    _ess_file="${ENV_SECRETS_FILE}"
elif [ -n "${HOME:-}" ] && [ -f "${HOME}/.env.secrets" ]; then
    _ess_file="${HOME}/.env.secrets"
elif [ -f "${PWD}/.env.secrets" ]; then
    _ess_file="${PWD}/.env.secrets"
elif [ -d "/workspace" ]; then
    for _ess_dir in /workspace/*/; do
        if [ -f "${_ess_dir}.env.secrets" ]; then
            _ess_file="${_ess_dir}.env.secrets"
            break
        fi
    done
fi

if [ -n "$_ess_file" ]; then
    set -a
    . "$_ess_file"
    set +a
fi

_ENV_SECRETS_LOADED=1

# Clean up
unset _ess_file _ess_dir

# Restore xtrace
eval "$_ess_old_xtrace"
unset _ess_old_xtrace
