services:
  devcontainer:
    build:
      context: ../
      dockerfile: ./{{ containers_dir }}/Dockerfile
      args:
        - BUILDKIT_INLINE_CACHE=1
        - PROJECT_NAME={{ project_name }}
        - USERNAME={{ username }}
        - BASE_IMAGE={{ base_image }}
{%- for group in build_arg_groups %}
        # {{ group.label }}
{%- for arg in group.args %}
{%- if arg.comment %}
        - {{ arg.line }}  # {{ arg.comment }}
{%- else %}
        - {{ arg.line }}
{%- endif %}
{%- endfor %}
{%- endfor %}
    env_file:
      - path: .env
        required: false
    environment:
      - ENVIRONMENT=development
{%- if needs_docker %}
      - DOCKER_BUILDKIT=1
{%- endif %}
    volumes:
      # Source code
      - ../:/workspace/{{ project_name }}:cached
{%- for mount in worktree_mounts %}
      # Agent worktree
      - {{ mount }}
{%- endfor %}
{%- if needs_docker %}
      # Docker socket
      - /var/run/docker.sock:/var/run/docker.sock
{%- endif %}
{%- for vol in cache_volumes %}
      - {{ vol.name }}:{{ vol.path }}
{%- endfor %}
      # VS Code extensions
      - vscode-extensions:/home/{{ username }}/.vscode-server/extensions
{%- if needs_bindfs %}
    cap_add:
      - SYS_ADMIN
    devices:
      - /dev/fuse
{%- endif %}
    networks:
      - dev-network
    restart: unless-stopped
    stdin_open: true
    tty: true
    init: true
    command: ["sleep", "infinity"]

volumes:
{%- for vol in cache_volumes %}
  {{ vol.name }}:
    driver: local
{%- endfor %}
  vscode-extensions:
    driver: local

networks:
  dev-network:
    name: {{ project_name }}-dev-network
    driver: bridge
