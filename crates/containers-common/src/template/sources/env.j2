# === IGOR:BEGIN ===
# Generated by igor
# Regenerate with: igor update

# Base environment
TZ=UTC
TERM=xterm-256color

# Runtime
ENVIRONMENT=development
{%- if "python" in features %}

# Python
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
PIP_NO_CACHE_DIR=1
POETRY_VIRTUALENVS_IN_PROJECT=true
POETRY_NO_INTERACTION=1
{%- endif %}
{%- if "node" in features %}

# Node.js
NODE_ENV=development
NPM_CONFIG_LOGLEVEL=warn
{%- endif %}
{%- if "rust" in features %}

# Rust
RUST_BACKTRACE=1
CARGO_INCREMENTAL=1
{%- endif %}
{%- if "golang" in features %}

# Go
GO111MODULE=on
GOPROXY=https://proxy.golang.org,direct
{%- endif %}
{%- if "ruby" in features %}

# Ruby
BUNDLE_PATH=vendor/bundle
{%- endif %}
{%- if "docker" in features %}

# Docker
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
{%- endif %}
{%- if "kubernetes" in features %}

# Kubernetes
KUBECONFIG=$HOME/.kube/config
{%- endif %}
{%- if "terraform" in features %}

# Terraform
TF_IN_AUTOMATION=true
TF_INPUT=false
{%- endif %}
{%- if "aws" in features %}

# AWS
AWS_DEFAULT_REGION=us-east-1
AWS_DEFAULT_OUTPUT=json
{%- endif %}
{%- if "dev_tools" in features %}

# Dev Tools
FZF_DEFAULT_OPTS=--height 40% --layout=reverse --border --info=inline
{%- endif %}
{%- if "ollama" in features %}

# Ollama
OLLAMA_HOST=http://localhost:11434
{%- endif %}
# === IGOR:END ===
