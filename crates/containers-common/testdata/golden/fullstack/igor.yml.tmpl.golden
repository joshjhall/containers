# Igor configuration — tracks feature selections and generated files
# Regenerate with: igor update

schema_version: 1
containers_dir: containers
project:
  name: fullstack
  username: dev
  base_image: debian:bookworm-slim
features:
  - python
  - python_dev
  - node
  - node_dev
  - rust
  - rust_dev
  - golang
  - golang_dev
  - dev_tools
  - docker
  - op
  - ollama
  - kubernetes
  - terraform
  - aws
  - postgres_client
  - redis_client
versions:
  GO_VERSION: "1.23"
  NODE_VERSION: "22"
  PYTHON_VERSION: "3.14"
  RUST_VERSION: "1.83"
