# Container Build System .gitignore

# ============================================================================
# OS GENERATED FILES
# ============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================================================
# FUSE FILESYSTEM ARTIFACTS
# ============================================================================

# Created by bindfs overlays when a file is deleted while still open —
# FUSE defers removal by renaming to .fuse_hiddenXXXX
.fuse_hidden*

# ============================================================================
# EDITOR DIRECTORIES AND FILES
# ============================================================================

.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ============================================================================
# CLAUDE LOCAL STATE
# ============================================================================

.claude/settings.local.json
.claude/memory/

# ============================================================================
# DOCKER BUILD ARTIFACTS
# ============================================================================

.dockerignore.local
docker-compose.override.yml
docker-compose.local.yml

# ============================================================================
# BUILD AND TEMPORARY FILES
# ============================================================================

*.log
*.pid
*.seed
*.pid.lock
*.tmp
temp/
tmp/
results/

# ============================================================================
# TEST ARTIFACTS
# ============================================================================

tests/results/
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/

# ============================================================================
# CACHE DIRECTORIES
# ============================================================================

# If mounted locally for testing
.cache/
cache/

# ============================================================================
# LANGUAGE-SPECIFIC EXCLUDES
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Rust
target/
Cargo.lock
**/*.rs.bk

# Go
*.exe
*.exe~
*.dll
*.dylib
*.test
*.out
vendor/

# Ruby
*.gem
*.rbc
.bundle/
.config
.yardoc
Gemfile.lock
_yardoc/
doc/
.ruby-version
.ruby-gemset

# Java
*.class
*.jar
*.war
*.ear
hs_err_pid*

# R
.Rhistory
.RData
.Ruserdata

# ============================================================================
# TERRAFORM
# ============================================================================

*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform.tfvars
*.tfvars

# ============================================================================
# ENVIRONMENT FILES (SECRETS)
# ============================================================================

# .env and .env.* in any directory
# Exception: .env.example and .env.*.example are allowed
.env
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# ============================================================================
# BACKUP FILES
# ============================================================================

*.bak
*.backup
*.backup-*
*.old

# Checksum database backups (created by bin/update-checksums.sh)
lib/checksums.json.backup-*

# ============================================================================
# ARCHIVE FILES
# ============================================================================

# Unless intentionally added
*.tar
*.gz
*.tgz
*.bz2
*.xz
*.7z
*.zip
*.rar

# ============================================================================
# RUNTIME AND PROCESS FILES
# ============================================================================

pids/
*.sock

# ============================================================================
# LOCAL DEVELOPMENT OVERRIDES
# ============================================================================

local/
.local/
