# Host Event Forwarding Feature Environment Variables
#
# Reports Claude Code agent state (working / waiting / idle / ended) to a host
# monitor's local HTTP bridge — e.g. Bartender's Top Shelf AI-agent feature,
# which listens on 127.0.0.1:7823 and shows each agent in the macOS menu bar.
# This makes agents running INSIDE containers visible on the host.

# Build Arguments
# ===============

# Bake the forwarder hook into the image. When false (default), no host-event
# hook is staged at all. When true, the hook is staged and can be turned on at
# RUNTIME via the same-named env var below — so one image serves both a
# monitored host and headless CI without a rebuild.
POST_CLAUDE_EVENTS_TO_HOST=false

# Runtime Environment Variables
# =============================

# Enable the forwarder at container start. Read every boot by claude-setup,
# which wires the hook into ~/.claude/settings.json when true. Requires the
# image to have been built with the build arg above = true.
# POST_CLAUDE_EVENTS_TO_HOST=true

# Where to reach the host monitor's bridge. The default is topology-aware and
# usually correct without setting these:
#   - Container / devcontainer golems:  host.docker.internal (auto-detected)
#   - Worktree golems (host tmux):       127.0.0.1 (they run ON the host)
# Override only when the monitor listens elsewhere (another machine, a custom
# port, or a Docker network where host.docker.internal is unavailable — then
# use the host-gateway IP).
# NOTCHBAR_AGENTS_HOST=host.docker.internal
# NOTCHBAR_AGENTS_PORT=7823

# docker-compose example (container golem reporting to the host):
#
#   services:
#     agent:
#       environment:
#         POST_CLAUDE_EVENTS_TO_HOST: "true"
#         NOTCHBAR_AGENTS_HOST: host.docker.internal
#         NOTCHBAR_AGENTS_PORT: "7823"
#       # If host.docker.internal is not provided by your Docker engine:
#       # extra_hosts:
#       #   - "host.docker.internal:host-gateway"
