# Development Tools Feature Environment Variables

# Build Arguments
# ===============

# Enable development tools installation
INCLUDE_DEV_TOOLS=false

# Runtime Environment Variables
# =============================

# fzf configuration
FZF_DEFAULT_OPTS=--height 40% --layout=reverse --border --info=inline
FZF_DEFAULT_COMMAND=fd --type f --hidden --follow --exclude .git
FZF_CTRL_T_COMMAND=fd --type f --hidden --follow --exclude .git
FZF_ALT_C_COMMAND=fd --type d --hidden --follow --exclude .git

# direnv configuration
DIRENV_LOG_FORMAT=
DIRENV_WARN_TIMEOUT=5s

# Git delta configuration
DELTA_PAGER=less
DELTA_FEATURES=side-by-side line-numbers decorations
DELTA_NAVIGATE=true

# GitHub CLI configuration
GH_CONFIG_DIR=$HOME/.config/gh
GH_PAGER=
GH_BROWSER=

# Just configuration
JUST_UNSTABLE=true
JUST_CHOOSER=fzf

# mkcert configuration
CAROOT=$HOME/.local/share/mkcert

# Claude Code CLI configuration
# ==============================

# Authentication (choose one method):
# 1. Interactive OAuth (browser-based):
#    Run 'claude' inside container and authenticate when prompted
# 2. Token-based (via proxy like LiteLLM):
#    Set ANTHROPIC_AUTH_TOKEN below
# ANTHROPIC_AUTH_TOKEN=your-token-here

# Default model (full model ID required, [1m] suffix for 1M context)
# Examples:
#   ANTHROPIC_MODEL=claude-opus-4-6[1m]          # Claude Opus 4.6 1M context (most capable)
#   ANTHROPIC_MODEL=claude-opus-4-6              # Claude Opus 4.6 200k context
#   ANTHROPIC_MODEL=claude-sonnet-4-6            # Claude Sonnet 4.6 (balanced)
#   ANTHROPIC_MODEL=claude-sonnet-4-5-20250929   # Claude Sonnet 4.5 (specific version)
#   ANTHROPIC_MODEL=claude-haiku-4-5-20251001    # Claude Haiku 4.5 (fastest)
# ANTHROPIC_MODEL=claude-opus-4-6[1m]

# Release channel (latest or stable)
# Default: latest (get new features immediately)
# Stable: ~1 week delay, skips releases with regressions
# CLAUDE_CHANNEL=latest

# Override core plugin set (comma-separated, replaces all 11 defaults)
# When unset: all defaults installed. When empty "": no core plugins.
# CLAUDE_EXTRA_PLUGINS remains additive on top.
# CLAUDE_PLUGINS=commit-commands,context7,code-review,pr-review-toolkit

# Override default MCP servers (comma-separated, replaces filesystem+figma-desktop)
# When unset: filesystem + figma-desktop. When empty "": no default MCPs.
# CLAUDE_EXTRA_MCPS remains additive on top.
# CLAUDE_MCPS=filesystem

# Override skill set (comma-separated, replaces all 13 static skills)
# container-environment always installs regardless. Conditional skills
# (docker-development, cloud-infrastructure) require both feature flag AND list entry.
# CLAUDE_SKILLS=git-workflow,code-quality,testing-patterns,development-workflow

# Override agent set (comma-separated, replaces all 11 default agents)
# CLAUDE_AGENTS=debugger,code-reviewer,test-writer

# Extra Claude Code plugins to install (comma-separated, additive)
# See: https://github.com/anthropics/claude-plugins
# CLAUDE_EXTRA_PLUGINS=stripe,posthog,vercel

# Extra MCP servers to install (comma-separated, additive)
# Available servers:
#   brave-search  - Brave Search API (requires BRAVE_API_KEY)
#   fetch         - URL fetching (no env vars required)
#   memory        - Persistent memory (optional: MEMORY_FILE_PATH)
#   sequential-thinking - Sequential thinking tool (no env vars required)
#   git           - Git operations (no env vars required)
#   sentry        - Sentry error tracking (requires SENTRY_ACCESS_TOKEN)
#   perplexity    - Perplexity AI search (requires PERPLEXITY_API_KEY)
#   kagi          - Kagi search (requires KAGI_API_KEY)
# CLAUDE_EXTRA_MCPS=brave-search,memory,fetch

# Extra skills (comma-separated, additive on top of CLAUDE_SKILLS)
# CLAUDE_EXTRA_SKILLS=my-custom-skill

# Extra agents (comma-separated, additive on top of CLAUDE_AGENTS)
# CLAUDE_EXTRA_AGENTS=my-custom-agent

# Auto-detect GitHub/GitLab MCP from git remotes (default: true)
# Set to false to disable automatic platform MCP detection
# CLAUDE_AUTO_DETECT_MCPS=true

# HTTP MCP auto-authentication (default: true)
# When ANTHROPIC_AUTH_TOKEN is set, automatically adds Authorization header
# to HTTP MCP servers from CLAUDE_EXTRA_MCPS.
# Set to false to disable auto-injection of auth headers.
# CLAUDE_MCP_AUTO_AUTH=true

# HTTP MCP with pipe-delimited custom headers:
# CLAUDE_EXTRA_MCPS=olympus=http://litellm:8080/mcp|Authorization:Bearer ${ANTHROPIC_AUTH_TOKEN}|X-Custom:value
